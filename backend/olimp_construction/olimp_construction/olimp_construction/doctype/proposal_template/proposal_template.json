{
  "name": "Proposal Template",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "field:template_id",
  "title_field": "title",
  "track_changes": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "template_id",
      "fieldtype": "Data",
      "label": "ID шаблона",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "description": "snake_case латиницей: industrial_contract, akz_proposal"
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Название",
      "reqd": 1,
      "in_list_view": 1,
      "bold": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Select",
      "label": "Категория",
      "options": "Промышленное строительство\nАКЗ / Огнезащита\nПромальп\nМонтаж м/к\nЛёгкий ремонт\nПрочее",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Активен",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "usage_count",
      "fieldtype": "Int",
      "label": "Использовано раз",
      "read_only": 1,
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "section_content",
      "fieldtype": "Section Break",
      "label": "Содержание"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Описание"
    },
    {
      "fieldname": "default_content_json",
      "fieldtype": "Long Text",
      "label": "TipTap JSON",
      "description": "Документ-шаблон с merge-тегами {{customer.name}} и т.п."
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "print": 1, "report": 1
    },
    {
      "role": "Главный инженер",
      "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1
    },
    {
      "role": "Тендерный менеджер",
      "read": 1, "write": 0, "report": 1
    }
  ],
  "sort_field": "usage_count",
  "sort_order": "DESC",
  "naming_rule": "By fieldname"
}
