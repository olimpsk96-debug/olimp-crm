{
  "name": "Estimate",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "EST-.YYYY.-.#####",
  "title_field": "title",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "title",
      "label": "Название сметы",
      "fieldtype": "Data",
      "reqd": 1,
      "in_list_view": 1,
      "in_global_search": 1,
      "bold": 1
    },
    {
      "fieldname": "status",
      "label": "Статус",
      "fieldtype": "Select",
      "options": "Базовая\nСкорректированная\nУтверждена\nАрхив",
      "default": "Базовая",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "version",
      "label": "Версия",
      "fieldtype": "Int",
      "default": "1",
      "in_list_view": 0
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "project",
      "label": "Проект",
      "fieldtype": "Link",
      "options": "Construction Project",
      "in_list_view": 1
    },
    {
      "fieldname": "tender",
      "label": "Тендер",
      "fieldtype": "Link",
      "options": "Tender"
    },
    {
      "fieldname": "estimate_date",
      "label": "Дата сметы",
      "fieldtype": "Date"
    },
    {
      "fieldname": "section_break_main",
      "label": "Позиции сметы",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "items",
      "label": "Позиции",
      "fieldtype": "Table",
      "options": "Estimate Item"
    },
    {
      "fieldname": "section_break_totals",
      "label": "Итоги",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "base_total",
      "label": "Сумма по нормам",
      "fieldtype": "Currency",
      "read_only": 1,
      "in_list_view": 1,
      "bold": 1
    },
    {
      "fieldname": "our_total",
      "label": "Наша цена",
      "fieldtype": "Currency",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "overhead_pct",
      "label": "Накладные расходы, %",
      "fieldtype": "Percent",
      "default": "0"
    },
    {
      "fieldname": "profit_pct",
      "label": "Сметная прибыль, %",
      "fieldtype": "Percent",
      "default": "0"
    },
    {
      "fieldname": "margin_pct",
      "label": "Маржа, %",
      "fieldtype": "Percent",
      "read_only": 1
    },
    {
      "fieldname": "margin_amount",
      "label": "Маржа, ₽",
      "fieldtype": "Currency",
      "read_only": 1
    },
    {
      "fieldname": "section_break_notes",
      "label": "Примечания",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "notes",
      "label": "Примечания",
      "fieldtype": "Text Editor"
    },
    {
      "fieldname": "import_source",
      "label": "Источник импорта",
      "fieldtype": "Select",
      "options": "\nГранд-Смета GS3\nГранд-Смета XML\nРучной ввод",
      "default": "Ручной ввод"
    },
    {
      "fieldname": "imported_at",
      "label": "Импортировано",
      "fieldtype": "Datetime",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}
