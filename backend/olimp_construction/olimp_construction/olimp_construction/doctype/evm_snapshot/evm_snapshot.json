{
  "name": "EVM Snapshot",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "format:EVMS-{project}-{snapshot_date}",
  "track_changes": 0,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Проект",
      "options": "Construction Project",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "snapshot_date",
      "fieldtype": "Date",
      "label": "Дата снимка",
      "reqd": 1,
      "in_list_view": 1,
      "default": "Today"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "health_level",
      "fieldtype": "Select",
      "label": "Здоровье",
      "options": "unknown\nexcellent\ngood\nwarning\ncritical\ndisaster",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "completion_pct",
      "fieldtype": "Percent",
      "label": "Выполнено, %",
      "in_list_view": 1
    },
    {
      "fieldname": "section_break_metrics",
      "fieldtype": "Section Break",
      "label": "Базовые метрики (₽)"
    },
    {
      "fieldname": "bac",
      "fieldtype": "Currency",
      "label": "BAC — Бюджет",
      "precision": "2"
    },
    {
      "fieldname": "ac",
      "fieldtype": "Currency",
      "label": "AC — Факт. расходы",
      "precision": "2"
    },
    {
      "fieldname": "ev",
      "fieldtype": "Currency",
      "label": "EV — Заработано",
      "precision": "2"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "pv",
      "fieldtype": "Currency",
      "label": "PV — План",
      "precision": "2"
    },
    {
      "fieldname": "eac",
      "fieldtype": "Currency",
      "label": "EAC — Прогноз",
      "precision": "2"
    },
    {
      "fieldname": "vac",
      "fieldtype": "Currency",
      "label": "VAC — Отклонение",
      "precision": "2"
    },
    {
      "fieldname": "section_break_indices",
      "fieldtype": "Section Break",
      "label": "Индексы"
    },
    {
      "fieldname": "cpi",
      "fieldtype": "Float",
      "label": "CPI",
      "precision": "3",
      "in_list_view": 1
    },
    {
      "fieldname": "spi",
      "fieldtype": "Float",
      "label": "SPI",
      "precision": "3",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "tcpi",
      "fieldtype": "Float",
      "label": "TCPI",
      "precision": "3"
    },
    {
      "fieldname": "etc",
      "fieldtype": "Currency",
      "label": "ETC — Осталось",
      "precision": "2"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "print": 1, "email": 1, "export": 1, "share": 1, "report": 1
    },
    {
      "role": "Главный инженер",
      "read": 1, "report": 1, "export": 1
    },
    {
      "role": "Тендерный менеджер",
      "read": 1, "report": 1
    }
  ],
  "sort_field": "snapshot_date",
  "sort_order": "DESC",
  "naming_rule": "Expression"
}
