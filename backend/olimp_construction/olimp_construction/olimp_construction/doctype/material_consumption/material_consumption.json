{
  "name": "Material Consumption",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "format:MC-{YYYY}-{#####}",
  "title_field": "material_name_text",
  "track_changes": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Проект",
      "options": "Construction Project",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "consumed_date",
      "fieldtype": "Date",
      "label": "Дата расхода",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "foreman_name",
      "fieldtype": "Data",
      "label": "Прораб / отчитался"
    },
    {
      "fieldname": "foreman_report",
      "fieldtype": "Link",
      "label": "Отчёт прораба",
      "options": "Foreman Report"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "stock_item",
      "fieldtype": "Link",
      "label": "Материал со склада",
      "options": "Stock Item",
      "description": "Если указан — авто-списание со склада при подтверждении",
      "in_list_view": 1
    },
    {
      "fieldname": "material_name_text",
      "fieldtype": "Data",
      "label": "Название (если нет на складе)",
      "in_list_view": 1
    },
    {
      "fieldname": "qty",
      "fieldtype": "Float",
      "label": "Кол-во",
      "reqd": 1,
      "in_list_view": 1,
      "precision": "3"
    },
    {
      "fieldname": "unit",
      "fieldtype": "Data",
      "label": "Ед. изм.",
      "in_list_view": 1
    },
    {
      "fieldname": "unit_price",
      "fieldtype": "Currency",
      "label": "Цена за ед."
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Сумма",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "section_status",
      "fieldtype": "Section Break",
      "label": "Статус"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Статус",
      "options": "Черновик\nПодтверждён\nСписан со склада\nОтклонён",
      "default": "Черновик",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "stock_movement_ref",
      "fieldtype": "Link",
      "label": "Stock Movement",
      "options": "Stock Movement",
      "read_only": 1
    },
    {
      "fieldname": "column_break_status",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "confirmed_by",
      "fieldtype": "Data",
      "label": "Подтвердил",
      "read_only": 1
    },
    {
      "fieldname": "confirmed_at",
      "fieldtype": "Datetime",
      "label": "Подтверждено",
      "read_only": 1
    },
    {
      "fieldname": "section_notes",
      "fieldtype": "Section Break",
      "label": "Детали",
      "collapsible": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Комментарий"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "print": 1, "report": 1
    },
    {
      "role": "Главный инженер",
      "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1
    },
    {
      "role": "Прораб",
      "read": 1, "write": 1, "create": 1, "report": 1
    }
  ],
  "sort_field": "consumed_date",
  "sort_order": "DESC",
  "naming_rule": "Expression"
}
