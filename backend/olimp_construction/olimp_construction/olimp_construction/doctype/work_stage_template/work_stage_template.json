{
  "name": "Work Stage Template",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "istable": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "stage_order",
      "fieldtype": "Int",
      "label": "№",
      "in_list_view": 1,
      "columns": 1
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Название этапа",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 4
    },
    {
      "fieldname": "unit",
      "fieldtype": "Data",
      "label": "Ед.",
      "in_list_view": 1,
      "columns": 1,
      "description": "м², м³, кг, шт, т, чел.-час"
    },
    {
      "fieldname": "norm_per_base_unit",
      "fieldtype": "Float",
      "label": "Норма на ед. шаблона",
      "precision": "4",
      "in_list_view": 1,
      "columns": 1,
      "description": "Например, шаблон в м², этап в чел.-час → 0.25 (15 мин/м²)"
    },
    {
      "fieldname": "labor_hours_per_unit",
      "fieldtype": "Float",
      "label": "Чел.-час/ед.",
      "precision": "3"
    },
    {
      "fieldname": "materials_json",
      "fieldtype": "Small Text",
      "label": "Материалы (JSON)",
      "description": "{\"primer_kg\": 0.3, \"abrasive_kg\": 35}",
      "columns": 3
    },
    {
      "fieldname": "gesn_ref",
      "fieldtype": "Data",
      "label": "ГЭСН/ФЕР",
      "description": "Например: ГЭСН 13-03-002-04",
      "columns": 2
    },
    {
      "fieldname": "catalog_resource",
      "fieldtype": "Link",
      "label": "Ресурс",
      "options": "Catalog Resource",
      "description": "Связь с CWICR (для актуальной цены)"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Примечание"
    }
  ]
}
