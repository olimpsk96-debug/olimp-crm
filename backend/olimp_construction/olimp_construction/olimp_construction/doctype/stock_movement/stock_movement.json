{
  "name": "Stock Movement",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "SM-.YYYY.-.#####",
  "title_field": "title",
  "track_changes": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Описание операции",
      "in_list_view": 1,
      "read_only": 1,
      "description": "Авто: '<Тип> <Материал>'"
    },
    {
      "fieldname": "movement_type",
      "fieldtype": "Select",
      "label": "Тип движения",
      "options": "Приход\nРасход\nПеремещение\nИнвентаризация",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "default": "Приход"
    },
    {
      "fieldname": "movement_date",
      "fieldtype": "Date",
      "label": "Дата",
      "reqd": 1,
      "default": "Today",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "stock_item",
      "fieldtype": "Link",
      "label": "Материал",
      "options": "Stock Item",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "qty",
      "fieldtype": "Float",
      "label": "Количество",
      "reqd": 1,
      "precision": "3",
      "in_list_view": 1,
      "description": "Для прихода — положительное; для расхода — будет вычитаться"
    },
    {
      "fieldname": "unit_price",
      "fieldtype": "Currency",
      "label": "Цена за ед.",
      "description": "Для прихода — закупочная цена"
    },
    {
      "fieldname": "section_break_links",
      "fieldtype": "Section Break",
      "label": "Связь"
    },
    {
      "fieldname": "warehouse",
      "fieldtype": "Data",
      "label": "Склад",
      "default": "Основной склад",
      "in_standard_filter": 1
    },
    {
      "fieldname": "warehouse_to",
      "fieldtype": "Data",
      "label": "Склад назначения (для перемещения)",
      "depends_on": "eval:doc.movement_type=='Перемещение'"
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Проект",
      "options": "Construction Project",
      "in_standard_filter": 1
    },
    {
      "fieldname": "material_request",
      "fieldtype": "Link",
      "label": "Заявка на материалы",
      "options": "Material Request",
      "description": "Если приход — по какой заявке"
    },
    {
      "fieldname": "column_break_links",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "supplier_name",
      "fieldtype": "Data",
      "label": "Поставщик (для прихода)"
    },
    {
      "fieldname": "invoice_number",
      "fieldtype": "Data",
      "label": "№ накладной / счёта"
    },
    {
      "fieldname": "responsible",
      "fieldtype": "Data",
      "label": "Ответственный (ФИО)",
      "description": "Кто принял / отпустил"
    },
    {
      "fieldname": "section_break_calc",
      "fieldtype": "Section Break",
      "label": "Итоги"
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Сумма (qty × цена)",
      "read_only": 1
    },
    {
      "fieldname": "balance_after",
      "fieldtype": "Float",
      "label": "Остаток после операции",
      "read_only": 1,
      "precision": "3"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Примечание"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "print": 1, "email": 1, "export": 1, "share": 1, "report": 1
    },
    {
      "role": "Снабженец",
      "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "print": 1, "export": 1
    },
    {
      "role": "Прораб",
      "read": 1, "create": 1, "write": 1,
      "if_owner": 1
    },
    {
      "role": "Бухгалтер Олимп",
      "read": 1, "report": 1, "export": 1
    }
  ],
  "sort_field": "movement_date",
  "sort_order": "DESC",
  "naming_rule": "Expression"
}
