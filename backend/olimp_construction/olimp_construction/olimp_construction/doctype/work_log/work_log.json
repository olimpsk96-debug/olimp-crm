{
  "name": "Work Log",
  "doctype": "DocType",
  "module": "Olimp Construction",
  "autoname": "WL-.YYYY.-.#####",
  "title_field": "title",
  "track_changes": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Объект / название журнала",
      "reqd": 1,
      "in_list_view": 1,
      "bold": 1,
      "description": "Например: «Общий журнал работ — ремонт ГШБ-3 НПП Старт»"
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Проект",
      "options": "Construction Project",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Статус",
      "options": "Ведётся\nЗакрыт\nПередан заказчику",
      "default": "Ведётся",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "started_date",
      "fieldtype": "Date",
      "label": "Дата начала ведения",
      "reqd": 1,
      "default": "Today",
      "in_list_view": 1
    },
    {
      "fieldname": "finished_date",
      "fieldtype": "Date",
      "label": "Дата окончания"
    },
    {
      "fieldname": "section_break_parties",
      "fieldtype": "Section Break",
      "label": "Стороны"
    },
    {
      "fieldname": "customer_name",
      "fieldtype": "Data",
      "label": "Заказчик"
    },
    {
      "fieldname": "customer_representative",
      "fieldtype": "Data",
      "label": "Представитель заказчика (тех.надзор)"
    },
    {
      "fieldname": "column_break_parties",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "contractor_name",
      "fieldtype": "Data",
      "label": "Подрядчик",
      "default": "ООО «Олимп»"
    },
    {
      "fieldname": "contractor_responsible",
      "fieldtype": "Data",
      "label": "Ответственный производитель работ"
    },
    {
      "fieldname": "section_break_entries",
      "fieldtype": "Section Break",
      "label": "Записи журнала"
    },
    {
      "fieldname": "entries",
      "fieldtype": "Table",
      "label": "Записи по дням",
      "options": "Work Log Entry"
    },
    {
      "fieldname": "section_break_summary",
      "fieldtype": "Section Break",
      "label": "Сводка (авто)"
    },
    {
      "fieldname": "entries_count",
      "fieldtype": "Int",
      "label": "Всего записей",
      "read_only": 1
    },
    {
      "fieldname": "total_workers_days",
      "fieldtype": "Int",
      "label": "Всего чел.-дней",
      "read_only": 1
    },
    {
      "fieldname": "column_break_summary",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "issues_count",
      "fieldtype": "Int",
      "label": "Замечаний",
      "read_only": 1
    },
    {
      "fieldname": "hidden_works_count",
      "fieldtype": "Int",
      "label": "Скрытых работ",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1,
      "print": 1, "email": 1, "export": 1, "share": 1, "report": 1
    },
    {
      "role": "Прораб",
      "read": 1, "write": 1, "create": 1, "print": 1
    },
    {
      "role": "Главный инженер",
      "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1, "report": 1
    },
    {
      "role": "Инженер ОТ-ТБ",
      "read": 1, "report": 1
    }
  ],
  "sort_field": "started_date",
  "sort_order": "DESC",
  "naming_rule": "Expression"
}
