{
  "name": "Deal",
  "module": "Olimp Construction",
  "doctype": "DocType",
  "autoname": "DL-.YYYY.-.#####",
  "is_submittable": 0,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Название",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Клиент",
      "options": "Customer",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "contact_name",
      "fieldtype": "Data",
      "label": "Контактное лицо"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Статус",
      "options": "Лид\nПереговоры\nКП отправлено\nДоговор\nВ работе\nЗакрыт выигран\nЗакрыт проигран",
      "default": "Лид",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "amount_estimated",
      "fieldtype": "Currency",
      "label": "Сумма (оценка)",
      "options": "RUB",
      "in_list_view": 1
    },
    {
      "fieldname": "probability_pct",
      "fieldtype": "Int",
      "label": "Вероятность, %",
      "default": 50
    },
    {
      "fieldname": "source",
      "fieldtype": "Select",
      "label": "Источник",
      "options": "\nСайт\nРекомендация\nТендер\nХолодный звонок\nЗнакомство\nПрочее"
    },
    {
      "fieldname": "expected_close_date",
      "fieldtype": "Date",
      "label": "Ожидаемое закрытие"
    },
    {
      "fieldname": "tender",
      "fieldtype": "Link",
      "label": "Тендер",
      "options": "Tender"
    },
    {
      "fieldname": "description",
      "fieldtype": "Text",
      "label": "Описание"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Заметки"
    },
    {
      "fieldname": "section_break_scoring",
      "fieldtype": "Section Break",
      "label": "Lead Scoring",
      "collapsible": 1
    },
    {
      "fieldname": "lead_score",
      "fieldtype": "Int",
      "label": "Score (0-100)",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Авто-оценка качества лида (правила)"
    },
    {
      "fieldname": "lead_grade",
      "fieldtype": "Select",
      "label": "Grade",
      "options": "\nA\nB\nC\nD",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "A=85+, B=65+, C=40+, D<40"
    },
    {
      "fieldname": "lead_score_breakdown",
      "fieldtype": "Small Text",
      "label": "Расшифровка score",
      "read_only": 1,
      "description": "JSON с разбивкой почему такой score"
    },
    {
      "fieldname": "section_break_pipeline",
      "fieldtype": "Section Break",
      "label": "Движение по воронке",
      "collapsible": 1
    },
    {
      "fieldname": "last_activity_date",
      "fieldtype": "Datetime",
      "label": "Последняя активность",
      "read_only": 1,
      "description": "Обновляется при смене статуса / комментарии / письме"
    },
    {
      "fieldname": "is_rotting",
      "fieldtype": "Check",
      "label": "Залежался (rotting)",
      "default": "0",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Сделка без активности больше N дней (threshold per stage)"
    },
    {
      "fieldname": "rotting_days",
      "fieldtype": "Int",
      "label": "Дней без активности",
      "read_only": 1
    },
    {
      "fieldname": "column_break_pipeline",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "loss_reason",
      "fieldtype": "Select",
      "label": "Причина проигрыша",
      "options": "\nЦена\nСроки\nКонкурент\nМолчание заказчика\nБюджет не утвердили\nНе наш профиль\nКачество КП\nДругое",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Обязательно при status=Закрыт проигран"
    },
    {
      "fieldname": "loss_competitor",
      "fieldtype": "Data",
      "label": "Кто выиграл (конкурент)",
      "description": "Если проиграли по цене/конкурент — кто выиграл"
    },
    {
      "fieldname": "loss_notes",
      "fieldtype": "Small Text",
      "label": "Детали проигрыша"
    },
    {
      "fieldname": "section_break_assignment",
      "fieldtype": "Section Break",
      "label": "Назначение",
      "collapsible": 1
    },
    {
      "fieldname": "assigned_to",
      "fieldtype": "Data",
      "label": "Назначен (email)",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Email ответственного менеджера. Заполняется auto round-robin или вручную."
    },
    {
      "fieldname": "assigned_at",
      "fieldtype": "Datetime",
      "label": "Назначен в",
      "read_only": 1
    },
    {
      "fieldname": "first_response_at",
      "fieldtype": "Datetime",
      "label": "Первый ответ менеджера",
      "read_only": 1,
      "description": "Когда менеджер впервые что-то сделал (изменил статус, добавил комментарий)"
    },
    {
      "fieldname": "column_break_assignment",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_missed",
      "fieldtype": "Check",
      "label": "Пропущен",
      "default": "0",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Менеджер не ответил больше N минут — лид нуждается в эскалации"
    },
    {
      "fieldname": "missed_minutes",
      "fieldtype": "Int",
      "label": "Мин без ответа",
      "read_only": 1
    }
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "All", "read": 1, "write": 1, "create": 1}
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
