# ═══════════════════════════════════════════════════════════════════
# .env.example для ООО «Олимп» ERP
# Скопируй в .env и заполни значения. НЕ коммить .env в git!
# ═══════════════════════════════════════════════════════════════════

# ─────── Домен и сайт ───────
DOMAIN=erp.olimp-ural.ru
SITE_NAME=erp.olimp-ural.ru
SSL_EMAIL=admin@olimp-ural.ru

# ─────── ERPNext ───────
ERPNEXT_DB_NAME=olimp_erp
ERPNEXT_ADMIN_PASSWORD=  # СГЕНЕРИРОВАТЬ: openssl rand -base64 32

# ─────── MariaDB ───────
MARIADB_ROOT_PASSWORD=   # СГЕНЕРИРОВАТЬ: openssl rand -base64 32

# ─────── MinIO ───────
MINIO_ROOT_USER=olimp_admin
MINIO_ROOT_PASSWORD=     # СГЕНЕРИРОВАТЬ: openssl rand -base64 32

# ─────── n8n ───────
N8N_USER=olimp_admin
N8N_PASSWORD=            # СГЕНЕРИРОВАТЬ: openssl rand -base64 24
N8N_ENCRYPTION_KEY=      # СГЕНЕРИРОВАТЬ: openssl rand -base64 32
N8N_DB_PASSWORD=         # СГЕНЕРИРОВАТЬ: openssl rand -base64 24

# ─────── Yandex Object Storage (бэкапы) ───────
YANDEX_S3_ACCESS_KEY=
YANDEX_S3_SECRET_KEY=

# ─────── Внешние API ───────
TELEGRAM_BOT_TOKEN=      # из @BotFather
TELEGRAM_DIRECTOR_CHAT_ID=  # ID чата Димы
ANTHROPIC_API_KEY=
OPENAI_API_KEY=          # для Whisper (голос → текст)
TENDEROK_API_KEY=        # подписка TenderOK

# ─────── Email (для Frappe + n8n) ───────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=erp@olimp-ural.ru
SMTP_PASSWORD=
SMTP_FROM=ERP Олимп <erp@olimp-ural.ru>

# ─────── Sentry (мониторинг ошибок, опционально) ───────
SENTRY_DSN=
