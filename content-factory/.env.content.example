# ============================================================
# Content Factory — Environment Variables
# Скопировать в .env.content и заполнить
# ============================================================

# --- LLM ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                    # для FLUX через gpt-image fallback + Whisper

# --- Trend discovery ---
SERPAPI_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
YANDEX_DIRECT_TOKEN=               # для Wordstat forecast API
TENDEROK_API_KEY=

# --- WordPress (promalp-ural.ru) ---
WP_URL=https://promalp-ural.ru
WP_URL_LOCAL=http://promalp.test
WP_USER=
WP_APP_PASSWORD=                   # Application Password из админки WP (НЕ пароль)
WP_DEFAULT_CATEGORY_ID=
WP_DEFAULT_AUTHOR_ID=

# --- Telegram (канал @promalp_ural) ---
TG_BOT_TOKEN=
TG_CHANNEL_ID=                     # @promalp_ural или числовой -1001234...
TG_CHAT_FOR_REVIEW=                # личный чат для preview перед публикацией

# --- Instagram ---
# Вариант A — официальный Meta Graph API (предпочтительно)
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
# Вариант B — instagrapi (fallback, серая зона)
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_PATH=/data/ig_session.json
IG_2FA_SECRET=                     # TOTP secret если включена 2FA

# --- TikTok ---
TIKTOK_USERNAME=
TIKTOK_COOKIES_PATH=/data/tiktok_cookies.txt
# Официальный TikTok Content Posting API (если получили approval)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# --- Analytics ---
GSC_SERVICE_ACCOUNT_JSON=/data/gsc-sa.json
GSC_SITE_URL=https://promalp-ural.ru/

GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=/data/ga4-sa.json

YANDEX_METRIKA_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_WEBMASTER_TOKEN=
YANDEX_WEBMASTER_USER_ID=
YANDEX_WEBMASTER_HOST_ID=

# --- Postiz ---
POSTIZ_MAIN_URL=http://localhost:5000
POSTIZ_JWT_SECRET=                 # случайная строка для JWT
POSTIZ_PG_PASSWORD=postiz_pwd
POSTIZ_API_KEY=

# --- AI Visibility tracking ---
AI_VIS_BRANDS=ОЛИМП,olimp,promalp-ural,промальп Екатеринбург,Кузьмин

# --- Infrastructure (используется existing olimp-erp инфра) ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=content-factory
REDIS_URL=redis://redis:6379/3
CONTENT_PG_PASSWORD=content_pwd

# --- ComfyUI ---
COMFYUI_URL=http://content-comfyui:8188

# --- Slack/Telegram уведомления о работе пайплайна ---
NOTIFY_TG_CHAT=                    # куда слать алерты

# --- Опции работы ---
DRAFT_MODE=true                    # если true — не публикует, а сохраняет черновики на review
AUTO_PUBLISH_WP=false
AUTO_PUBLISH_TG=false
AUTO_PUBLISH_IG=false
AUTO_PUBLISH_TT=false
ARTICLES_PER_DAY=2
ANALYTICS_RUN_DAY=sunday
ANALYTICS_RUN_HOUR=22
REFRESH_LOOP_ENABLED=true
DECAY_THRESHOLD_PCT=20             # просадка позиций для запуска refresh
DECAY_WEEKS_WINDOW=4
