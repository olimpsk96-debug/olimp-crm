# =============================================================================
# OLIMP.ESTIMATE — переменные окружения
# Скопировать в .env.olimp и заполнить
# =============================================================================

# --- БД OpenConstructionERP (отдельный Postgres) ---
OCE_DB_PASSWORD=ChangeMe_Strong_Password_Here_32chars
OCE_SECRET_KEY=ChangeMe_Random_64_chars_Generate_With_openssl_rand_base64_48

# --- LLM-провайдеры ---
# Anthropic — основной для AI Cost Advisor и генерации BOQ
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI — только для embeddings (text-embedding-3-large)
# Если не хочешь зависеть от OpenAI — можно использовать
# self-hosted bge-m3 (multilingual) или e5-large-multilingual
OPENAI_API_KEY=sk-...

# --- MinIO (берём из основного .env, дублируем здесь для явности) ---
MINIO_ROOT_USER=olimp_minio_admin
MINIO_ROOT_PASSWORD=ChangeMe_MinIO_Password_Here

# --- Домены ---
OCE_DOMAIN=estimate.olimp-ural.ru

# --- Telegram (для алертов превышения бюджета, новых BOQ и т.п.) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_ESTIMATORS=     # чат сметчиков
TELEGRAM_CHAT_ID_DIRECTOR=       # личный чат директора

# --- Региональные настройки ---
DEFAULT_REGION=RU-URAL
DEFAULT_CURRENCY=RUB
DEFAULT_VAT_RATE=20
DEFAULT_LANGUAGE=ru

# --- Интеграция с ERPNext ---
ERPNEXT_API_URL=http://erpnext-backend:8000
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
